{
  "name": "@cyclonedx/sign",
  "version": "0.3.0",
  "description": "Standalone TypeScript implementation of JSON Signature Format (JSF), JSON Signature Schema (JSS, X.590), and the JSON Canonicalization Scheme (JCS, RFC 8785). Single library covering CycloneDX 1.x (JSF) and 2.x (JSS). The only runtime dependency beyond Node crypto is @noble/curves, used solely for JSS ECDSA pre-hashed signing.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsf": {
      "types": "./dist/jsf/index.d.ts",
      "import": "./dist/jsf/index.js"
    },
    "./jss": {
      "types": "./dist/jss/index.d.ts",
      "import": "./dist/jss/index.js"
    },
    "./jcs": {
      "types": "./dist/jcs.d.ts",
      "import": "./dist/jcs.js"
    },
    "./jwk": {
      "types": "./dist/jwk.d.ts",
      "import": "./dist/jwk.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "keywords": [
    "cyclonedx",
    "sbom",
    "signature",
    "signatures",
    "jsf",
    "json-signature-format",
    "jss",
    "json-signature-schema",
    "x590",
    "jcs",
    "rfc8785",
    "canonicalization"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/curves": "2.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
